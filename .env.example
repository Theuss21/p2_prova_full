# Segredo usado pelo backend para assinar/validar tokens JWT
JWT_SECRET=super_secret_key_123

# URL pela qual o navegador do usuário acessa a API (porta publicada do
# serviço "api" no docker-compose). Mude se o backend rodar em outra
# porta/host (ex: ao publicar em produção).
FRONTEND_API_URL=http://localhost:3000
