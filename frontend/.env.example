# URL base da API backend.
# - Em desenvolvimento local (npm run dev), o Vite expõe esta variável via import.meta.env.VITE_API_URL
# - Em produção (Docker), o valor real é definido pela variável API_URL no docker-compose.yml
#   e injetado em tempo de execução no arquivo public/env-config.js (ver docker-entrypoint.sh)
VITE_API_URL=http://localhost:3000
